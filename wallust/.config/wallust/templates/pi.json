{
  "$schema": "https://raw.githubusercontent.com/badlogic/pi-mono/main/packages/coding-agent/src/modes/interactive/theme/theme-schema.json",
  "name": "wallust",
  "vars": {
    "bg": "{{background}}",
    "fg": "{{foreground}}",
    "black": "{{color0}}",
    "red": "{{color1}}",
    "green": "{{color2}}",
    "yellow": "{{color3}}",
    "blue": "{{color4}}",
    "magenta": "{{color5}}",
    "cyan": "{{color6}}",
    "white": "{{color7}}",
    "brightBlack": "{{color8}}",
    "brightRed": "{{color9}}",
    "brightGreen": "{{color10}}",
    "brightYellow": "{{color11}}",
    "brightBlue": "{{color12}}",
    "brightMagenta": "{{color13}}",
    "brightCyan": "{{color14}}",
    "brightWhite": "{{color15}}"
  },
  "colors": {
    "accent": "cyan",
    "border": "blue",
    "borderAccent": "brightCyan",
    "borderMuted": "brightBlack",
    "success": "green",
    "error": "red",
    "warning": "yellow",
    "muted": "brightBlack",
    "dim": "brightBlack",
    "text": "",
    "thinkingText": "brightBlack",

    "selectedBg": "blue",
    "userMessageBg": "black",
    "userMessageText": "fg",
    "customMessageBg": "magenta",
    "customMessageText": "fg",
    "customMessageLabel": "brightMagenta",
    "toolPendingBg": "black",
    "toolSuccessBg": "green",
    "toolErrorBg": "red",
    "toolTitle": "fg",
    "toolOutput": "brightBlack",

    "mdHeading": "brightYellow",
    "mdLink": "brightBlue",
    "mdLinkUrl": "brightBlack",
    "mdCode": "brightCyan",
    "mdCodeBlock": "brightGreen",
    "mdCodeBlockBorder": "brightBlack",
    "mdQuote": "brightBlack",
    "mdQuoteBorder": "brightBlack",
    "mdHr": "brightBlack",
    "mdListBullet": "brightCyan",

    "toolDiffAdded": "brightGreen",
    "toolDiffRemoved": "brightRed",
    "toolDiffContext": "brightBlack",

    "syntaxComment": "brightBlack",
    "syntaxKeyword": "brightBlue",
    "syntaxFunction": "brightYellow",
    "syntaxVariable": "brightCyan",
    "syntaxString": "brightGreen",
    "syntaxNumber": "brightMagenta",
    "syntaxType": "cyan",
    "syntaxOperator": "fg",
    "syntaxPunctuation": "fg",

    "thinkingOff": "brightBlack",
    "thinkingMinimal": "white",
    "thinkingLow": "blue",
    "thinkingMedium": "cyan",
    "thinkingHigh": "magenta",
    "thinkingXhigh": "brightMagenta",

    "bashMode": "green"
  },
  "export": {
    "pageBg": "{{background}}",
    "cardBg": "{{color0}}",
    "infoBg": "{{color8}}"
  }
}
